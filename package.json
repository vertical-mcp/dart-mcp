{
  "name": "@vertical-mcp/dart-mcp",
  "version": "0.1.0",
  "description": "MCP server for Korea's DART (Electronic Disclosure) — company disclosures, financial statements, and corporate events via OpenDART.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "dart",
    "opendart",
    "korea",
    "finance",
    "disclosure",
    "xbrl",
    "kospi",
    "kosdaq"
  ],
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "dart-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "smithery.yaml"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "undici": "^6.19.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "esbuild": "^0.27.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Yongbum Kim <kyb8801@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vertical-mcp/dart-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/vertical-mcp/dart-mcp/issues"
  },
  "homepage": "https://github.com/vertical-mcp/dart-mcp#readme",
  "publishConfig": {
    "access": "public"
  }
}
